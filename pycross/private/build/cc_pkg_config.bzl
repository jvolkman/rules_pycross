"""A rule that generates a pkg-config (.pc) file dynamically from a CcInfo provider target."""

load("@rules_cc//cc/common:cc_info.bzl", "CcInfo")
load("//pycross/private:cc_toolchain_util.bzl", "absolutize_path_in_str", "get_libraries")

def _uniq(lst):
    res = []
    seen = {}
    for item in lst:
        if item not in seen:
            seen[item] = True
            res.append(item)
    return res

def _get_lib_flag(file):
    basename = file.basename
    if basename.startswith("lib"):
        name = basename[3:]
    else:
        name = basename

    parts = name.split(".")
    for i, part in enumerate(parts):
        if part in ("so", "a", "dylib", "lib", "dll"):
            name = ".".join(parts[:i])
            break
    return "-l" + name

def _pycross_cc_pkg_config_impl(ctx):
    cc_info = ctx.attr.dep[CcInfo]

    # 1. Gather and resolve include paths
    comp_ctx = cc_info.compilation_context
    raw_includes = (
        comp_ctx.system_includes.to_list() +
        comp_ctx.includes.to_list() +
        comp_ctx.quote_includes.to_list()
    )
    unique_includes = _uniq(raw_includes)
    cflags = []
    for inc in unique_includes:
        abs_inc = absolutize_path_in_str(ctx.workspace_name, "$$EXT_BUILD_ROOT$$/", inc)
        cflags.append("-I" + abs_inc)

    # 2. Gather and resolve library paths
    libs = get_libraries(cc_info)
    lib_dirs = []
    lib_flags = []
    for lib in libs:
        lib_dirs.append(lib.dirname)
        lib_flags.append(_get_lib_flag(lib))

    unique_lib_dirs = _uniq(lib_dirs)
    unique_lib_flags = _uniq(lib_flags)

    libs_field_parts = []
    for lib_dir in unique_lib_dirs:
        abs_lib_dir = absolutize_path_in_str(ctx.workspace_name, "$$EXT_BUILD_ROOT$$/", lib_dir)
        libs_field_parts.append("-L" + abs_lib_dir)
    libs_field_parts.extend(unique_lib_flags)

    # 3. Generate .pc content
    pc_file = ctx.actions.declare_file(ctx.attr.lib_name + ".pc")

    pc_content = [
        "Name: " + ctx.attr.lib_name,
        "Description: " + ctx.attr.description,
        "Version: " + ctx.attr.version,
        "Libs: " + " ".join(libs_field_parts),
        "Cflags: " + " ".join(cflags),
    ]

    ctx.actions.write(
        output = pc_file,
        content = "\n".join(pc_content) + "\n",
    )

    return [
        DefaultInfo(
            files = depset([pc_file]),
            runfiles = ctx.runfiles(files = [pc_file]),
        ),
    ]

pycross_cc_pkg_config = rule(
    implementation = _pycross_cc_pkg_config_impl,
    attrs = {
        "dep": attr.label(
            mandatory = True,
            providers = [CcInfo],
            doc = "The CC dependency target supplying CcInfo",
        ),
        "lib_name": attr.string(
            mandatory = True,
            doc = "The name of the pkg-config package (outputs lib_name.pc)",
        ),
        "version": attr.string(
            mandatory = True,
            doc = "The version of the pkg-config package",
        ),
        "description": attr.string(
            default = "Generated by pycross_cc_pkg_config",
            doc = "The description of the pkg-config package",
        ),
    },
)
