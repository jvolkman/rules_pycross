bazel_dep(name = "rules_pycross", version = "0.0.0")
bazel_dep(name = "rules_pycross_e2e_shared", version = "0.0.0")
bazel_dep(name = "rules_python", version = "2.0.0")

local_path_override(
    module_name = "rules_pycross",
    path = "../../..",
)

local_path_override(
    module_name = "rules_pycross_e2e_shared",
    path = "../shared",
)

# rules_python
python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.11.6",
)
python.toolchain(python_version = "3.12.0")
use_repo(python, "python_versions")

# rules_pycross
environments = use_extension("@rules_pycross//pycross/extensions:environments.bzl", "environments")
environments.create_for_python_toolchains(
    name = "multi_lock_universe_envs",
    platforms = [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
    ],
)
use_repo(environments, "multi_lock_universe_envs")

# Use the lock_import extension to import two lock files sharing a workspace.
lock_import = use_extension("@rules_pycross//pycross/extensions:lock_import.bzl", "lock_import")

# Project A: regex + six
lock_import.import_uv(
    lock_file = "//project_a:uv.lock",
    project_file = "//project_a:pyproject.toml",
    repo = "lock_a",
    target_environments = ["@multi_lock_universe_envs//:environments"],
    workspace = "shared",
)

# Project B: regex + attrs
lock_import.import_uv(
    lock_file = "//project_b:uv.lock",
    project_file = "//project_b:pyproject.toml",
    repo = "lock_b",
    target_environments = ["@multi_lock_universe_envs//:environments"],
    workspace = "shared",
)

# Annotation conflict: exclude a test file from regex in lock_a only.
# This triggers per-member variant targets in the workspace.
lock_import.package(
    name = "regex",
    install_exclude_globs = ["test_regex.py"],
    repo = "lock_a",
)
use_repo(lock_import, "lock_import_repos_hub")

# The actual repos are loaded from the lock_repos extension.
lock_repos = use_extension("@rules_pycross//pycross/extensions:lock_repos.bzl", "lock_repos")
use_repo(lock_repos, "lock_a", "lock_b")
