load("@rules_python//python:defs.bzl", "py_binary")
load("@uv//_backend:setuptools_build.bzl", "setuptools_build")

package(default_visibility = ["//visibility:public"])

# Expose pg_config on PATH hermetically.
# Since it is named 'pg_config', it will map to 'pg_config' on PATH.
py_binary(
    name = "pg_config",
    srcs = ["pg_config.py"],
)

# Build psycopg2 utilizing the Setuptools build backend macro.
# build_deps default to locked [setuptools, wheel].
setuptools_build(
    name = "wheel",
    native_deps = [
        "//third_party/postgresql",
    ],
    path_tools = [
        ":pg_config",
    ],
    resource_size = "medium",
    sdist = "@uv//psycopg2:sdist",
)
