# Shared overrides for rules_foreign_cc.
# Pin to main HEAD (d1c7b2b) for resource_size support, with patches:
# - CPPFLAGS: set during GNU Make bootstrap so configure scripts find headers
#   with hermetic toolchains.
# - cmake cross-compilation: map aarch64 to arm64 on Apple platforms, and make
#   CMAKE_SYSTEM_NAME/CMAKE_SYSTEM_PROCESSOR replaceable so user cache_entries
#   override rather than concatenate with auto-detected values.
archive_override(
    module_name = "rules_foreign_cc",
    integrity = "sha256-XhngvpzWyhUahYlQtOdv1o8dE5yhgLFMJmVmaPNMLYw=",
    patch_strip = 1,
    patches = [
        "//shared/patches:rules_foreign_cc-cppflags.patch",
        "//shared/patches:rules_foreign_cc-cmake-xcompile.patch",
    ],
    strip_prefix = "rules_foreign_cc-d1c7b2be20edfd4a94731077426c42ae8cd8be1e",
    urls = ["https://github.com/bazel-contrib/rules_foreign_cc/archive/d1c7b2be20edfd4a94731077426c42ae8cd8be1e.tar.gz"],
)
