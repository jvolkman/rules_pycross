bazel_dep(name = "rules_pycross", version = "0.0.0")
bazel_dep(name = "rules_pycross_e2e_shared", version = "0.0.0")
bazel_dep(name = "rules_python", version = "2.0.0")

local_path_override(
    module_name = "rules_pycross",
    path = "../../..",
)

local_path_override(
    module_name = "rules_pycross_e2e_shared",
    path = "../shared",
)

# rules_python
python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.11.6",
)
python.toolchain(python_version = "3.12.0")
use_repo(python, "python_versions")

# rules_pycross - use per-platform tag API
environments = use_extension("@rules_pycross//pycross/extensions:environments.bzl", "environments")
environments.create_for_python_toolchains(
    name = "pdm_workspace_envs",
)
environments.platform(
    name = "pdm_workspace_envs",
    target = "aarch64-apple-darwin",
)
environments.platform(
    name = "pdm_workspace_envs",
    target = "x86_64-unknown-linux-gnu",
)
use_repo(environments, "pdm_workspace_envs")

pdm = use_extension("@rules_pycross//pycross/extensions:pdm.bzl", "pdm")
pdm.workspace(
    name = "shared",
    extra_project_files = ["//project_c:pyproject.toml"],
    lock_file = "//:pdm.lock",
)
pdm.repo(
    name = "lock_c",
    projects = ["project-c"],
    workspace = "shared",
)
pdm.repo(
    name = "lock_all",
    projects = ["*"],
    workspace = "shared",
)

# Override project-a's repo name; project-b uses the pattern default (lock_project_b).
pdm.repo(
    name = "lock_a",
    projects = ["project-a"],
    workspace = "shared",
)
pdm.repo(
    name = "lock_project_b",
    projects = ["project-b"],
    workspace = "shared",
)

# Annotation conflict: exclude a test file from regex across the whole workspace.
pdm.package(
    name = "regex",
    install_exclude_globs = ["test_regex.py"],
    workspace = "shared",
)
use_repo(pdm, "lock_a", "lock_all", "lock_c", "lock_project_b")
