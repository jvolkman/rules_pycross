bazel_dep(name = "rules_pycross", version = "0.0.0")
bazel_dep(name = "rules_pycross_e2e_shared", version = "0.0.0")
bazel_dep(name = "rules_python", version = "2.0.0")

local_path_override(
    module_name = "rules_pycross",
    path = "../../..",
)

local_path_override(
    module_name = "rules_pycross_e2e_shared",
    path = "../shared",
)

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.11.6",
)
python.toolchain(python_version = "3.12.0")
use_repo(python, "python_versions")

uv = use_extension("@rules_pycross//pycross/extensions:uv.bzl", "uv")
uv.workspace(
    name = "cycle_lock",
    local_wheels = [
        "//:cycle_a-1.0.0-py3-none-any.whl",
        "//:cycle_b-1.0.0-py3-none-any.whl",
    ],
    lock_file = "//:uv.lock",
)
uv.repo(
    workspace = "cycle_lock",
)
use_repo(uv, "cycle_lock", "cycle_lock__build")
