include("//shared:llvm.MODULE.bazel")

bazel_dep(name = "rules_cc", version = "0.2.18")
bazel_dep(name = "rules_python", version = "2.0.0")
bazel_dep(name = "rules_pycross", version = "0.0.0")
bazel_dep(name = "bazel_lib", version = "3.2.0")
bazel_dep(name = "rules_foreign_cc", version = "0.15.1")

include("//shared:overrides.MODULE.bazel")

bazel_dep(name = "bazel_skylib", version = "1.9.0")

local_path_override(
    module_name = "rules_pycross",
    path = "../../..",
)

# Third party deps
include("//third_party/openblas:repositories.MODULE.bazel")

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.14.2",
)
use_repo(python, "python_versions")

pycross = use_extension("@rules_pycross//pycross/extensions:pycross.bzl", "pycross")
pycross.configure_toolchains(
    platforms = [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
    ],
    python_versions = [
        "3.14.2",
    ],
)

lock = use_extension("@rules_pycross//pycross/extensions:lock.bzl", "lock")
lock.import_uv(
    default_alias_single_version = True,
    lock_file = "//:uv.lock",
    project_file = "//:pyproject.toml",
    repo = "uv",
)
lock.package(
    name = "numpy",
    always_build = True,
    build_target = "@//deps/numpy:wheel",
    repo = "uv",
)
lock.package(
    name = "pandas",
    always_build = True,
    build_target = "@//deps/pandas:wheel",
    repo = "uv",
)
lock.package(
    name = "contourpy",
    always_build = True,
    build_target = "@//deps/contourpy:wheel",
    repo = "uv",
)
lock.package(
    name = "pywavelets",
    always_build = True,
    build_target = "@//deps/pywavelets:wheel",
    repo = "uv",
)
use_repo(lock, "uv")
