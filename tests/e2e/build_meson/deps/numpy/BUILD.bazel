load("@rules_pycross//pycross:defs.bzl", "pycross_cc_pkg_config", "pycross_wheel_library")
load("@rules_python//python/entry_points:py_console_script_binary.bzl", "py_console_script_binary")
load("@uv//_backend:meson_build.bzl", "meson_build")
load(":numpy_headers.bzl", "numpy_cc_library")

package(default_visibility = ["//visibility:public"])

pycross_cc_pkg_config(
    name = "gen_openblas_pc_file",
    dep = "//third_party/openblas",
    lib_name = "scipy-openblas",
    version = "0.3.20",
)

py_console_script_binary(
    name = "cython",
    pkg = "@uv//cython",
    script = "cython",
)

meson_build(
    name = "wheel",
    build_deps = [
        "@uv//meson:pkg",
        "@uv//ninja:pkg",
        "@uv//cython:pkg",
    ],
    config_settings = {
        "setup-args": [],
        "compile-args": ["-v"],
    },
    copts = ["-Wl,-s"],
    native_deps = [
        "//third_party/openblas",
    ],
    path_tools = [":cython"],
    pkg_config_files = [":gen_openblas_pc_file"],
    resource_size = "medium",
    sdist = "@uv//numpy:sdist",
)

# Unzip the wheel for downstream header extraction.
pycross_wheel_library(
    name = "numpy",
    wheel = ":wheel",
)

numpy_cc_library(
    name = "numpy_headers",
    numpy_wheel_dep = ":numpy",
)
