load("@rules_pycross//pycross:defs.bzl", "pycross_console_script_binary")
load("@uv//_backend:meson_build.bzl", "meson_build")

package(default_visibility = ["//visibility:public"])

pycross_console_script_binary(
    name = "pybind11-config",
    pkg = "@uv//pybind11:pybind11",
    script = "pybind11-config",
)

meson_build(
    name = "wheel",
    build_deps = [
        "@uv//meson:meson",
        "@uv//ninja:ninja",
        "@uv//pybind11:pybind11",
        "@uv//numpy:numpy",
    ],
    meson_properties = {
        "numpy-include-dir": "$(NUMPY_INCLUDE_DIR)",
    },
    native_deps = [
        "//deps/numpy:numpy_headers",
    ],
    path_tools = [":pybind11-config"],
    sdist = "@uv//contourpy:sdist",
    deps = [
        "@uv//numpy:numpy",
    ],
)
