load("@rules_python//python:defs.bzl", "py_test")

py_test(
    name = "test_numpy",
    srcs = ["test_numpy.py"],
    deps = ["@uv//numpy:numpy"],
)

py_test(
    name = "test_pandas",
    srcs = ["test_pandas.py"],
    deps = [
        "@uv//numpy:numpy",
        "@uv//pandas:pandas",
    ],
)

py_test(
    name = "test_contourpy",
    srcs = ["test_contourpy.py"],
    deps = [
        "@uv//contourpy:contourpy",
        "@uv//numpy:numpy",
    ],
)

py_test(
    name = "test_pywavelets",
    srcs = ["test_pywavelets.py"],
    deps = [
        "@uv//numpy:numpy",
        "@uv//pywavelets:pywavelets",
    ],
)
