load("@rules_python//python:defs.bzl", "py_test")
load("@uv//:requirements.bzl", "all_requirements", "requirement")

package(default_visibility = ["//visibility:public"])

py_test(
    name = "test_namespace",
    srcs = ["test_namespace.py"],
    deps = all_requirements,
)

py_test(
    name = "test_namespace_direct",
    srcs = ["test_namespace.py"],
    main = "test_namespace.py",
    deps = [
        requirement("google-cloud-storage"),
        requirement("google-cloud-pubsub"),
        requirement("zope.interface"),
        requirement("zope.event"),
    ],
)

py_test(
    name = "test_extras_aliases",
    srcs = ["test_extras_aliases.py"],
    deps = [
        requirement("google-api-core"),
    ],
)
