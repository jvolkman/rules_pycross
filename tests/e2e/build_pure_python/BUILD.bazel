load("@rules_python//python:defs.bzl", "py_test")
load("//shared:collect_wheels.bzl", "collect_wheels")

collect_wheels(
    name = "all_wheels",
    platforms = [
        "@llvm//platforms:linux_x86_64",
        "@llvm//platforms:macos_aarch64",
    ],
    wheels = [
        "@uv//filelock:wheel",
        "@uv//pyproject_metadata:wheel",
        "@uv//tomli:wheel",
    ],
)

py_test(
    name = "test_top_level_packages",
    srcs = ["@rules_pycross_e2e_shared//:test_top_level_packages.py"],
    env = {
        # Tell the test which packages to check (sdist-built pure Python)
        "PYCROSS_TEST_PACKAGES": "tomli,filelock",
    },
    main = "test_top_level_packages.py",
    deps = [
        "@uv//filelock:pkg",
        "@uv//tomli:pkg",
    ],
)
