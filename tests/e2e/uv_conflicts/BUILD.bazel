load("@rules_python//python:defs.bzl", "py_test")

# Platforms that select conflict variants via bool_flag settings.
# @project//_variants:extra_variant-a and @project//_variants:extra_variant-b
# are bool_flags generated by pycross from the uv conflict declarations.

platform(
    name = "plat_variant_a",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    flags = [
        "--@project//_variants:extra_variant-a=True",
    ],
)

platform(
    name = "plat_variant_b",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    flags = [
        "--@project//_variants:extra_variant-b=True",
    ],
)

# Test that variant-a resolves typing_extensions 4.11.0.
py_test(
    name = "test_variant_a",
    srcs = ["tests/test_conflict_version.py"],
    args = [
        "typing-extensions",
        "4.11.0",
    ],
    main = "tests/test_conflict_version.py",
    deps = ["@project//:typing-extensions"],
)

# Test that variant-b resolves typing_extensions 4.12.2.
py_test(
    name = "test_variant_b",
    srcs = ["tests/test_conflict_version.py"],
    args = [
        "typing-extensions",
        "4.12.2",
    ],
    main = "tests/test_conflict_version.py",
    deps = ["@project//:typing-extensions"],
)

# Test that default-groups makes group-a the default:
# idna should resolve to 3.7 without any flags because group-a is the default.
py_test(
    name = "test_default_group",
    srcs = ["tests/test_conflict_version.py"],
    args = [
        "idna",
        "3.7",
    ],
    main = "tests/test_conflict_version.py",
    deps = ["@project//:idna"],
)
