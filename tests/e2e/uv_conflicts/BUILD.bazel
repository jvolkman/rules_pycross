alias(
    name = "torch_cpu",
    actual = "@cpu//torch",
    target_compatible_with = ["@cpu//_constraints:cpu"],
)

alias(
    name = "torch_gpu",
    actual = "@gpu//torch",
    target_compatible_with = ["@gpu//_constraints:cu124"],
)

platform(
    name = "plat_cpu",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@cpu//_constraints:cpu",
    ],
)

platform(
    name = "plat_gpu",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@gpu//_constraints:cu124",
    ],
)
