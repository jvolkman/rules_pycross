# Platforms that select conflict variants via constraint values.
# @project//_constraints:extra_cpu and @project//_constraints:extra_cu124 are
# generated by pycross from the uv conflict declarations.

platform(
    name = "plat_cpu",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@project//_constraints:extra_cpu",
    ],
)

platform(
    name = "plat_gpu",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@project//_constraints:extra_cu124",
    ],
)
