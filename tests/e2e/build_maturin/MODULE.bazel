include("//shared:llvm.MODULE.bazel")

bazel_dep(name = "rules_cc", version = "0.2.18")
bazel_dep(name = "rules_python", version = "2.0.0")
bazel_dep(name = "rules_pycross", version = "0.0.0")
bazel_dep(name = "rules_pycross_backend_maturin", version = "0.0.0")
bazel_dep(name = "bazel_lib", version = "3.2.0")
bazel_dep(name = "rules_rust", version = "0.68.0")

rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(
    edition = "2021",
    extra_target_triples = [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
    ],
)

local_path_override(
    module_name = "rules_pycross",
    path = "../../..",
)

local_path_override(
    module_name = "rules_pycross_backend_maturin",
    path = "../../../modules/backend_maturin",
)

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.14.2",
)
use_repo(python, "python_versions")

pycross = use_extension("@rules_pycross//pycross/extensions:pycross.bzl", "pycross")
pycross.configure_toolchains(
    platforms = [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
    ],
    python_versions = [
        "3.14.2",
    ],
)

uv = use_extension("@rules_pycross//pycross/extensions:uv.bzl", "uv")
uv.workspace(
    name = "uv",
    lock_file = "//:uv.lock",
)
uv.repo(
    alias_transitive = True,
    project_file = "//:pyproject.toml",
    workspace = "uv",
)
uv.package(
    name = "rpds-py",
    always_build = True,
    workspace = "uv",
)
uv.package(
    name = "jiter",
    always_build = True,
    workspace = "uv",
)
uv.package(
    name = "python-geohash",
    always_build = True,
    workspace = "uv",
)

maturin = use_extension("@rules_pycross_backend_maturin//extensions:maturin.bzl", "maturin")
maturin.override(
    name = "jiter",
    cargo_lock = "//:jiter.lock",
    sdist = "@uv//jiter:sdist",
    workspace = "uv",
)

use_repo(uv, "uv")
