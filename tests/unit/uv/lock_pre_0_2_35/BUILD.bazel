"""
Previously uv used `distribution` instead of `packages` in `uv.lock`.

This has changed in the following PR:
  https://github.com/astral-sh/uv/pull/5861

This PR was contained in the following release:
  https://github.com/astral-sh/uv/releases/tag/0.2.35
"""

load("@bazel_lib//lib:write_source_files.bzl", "write_source_file")
load("@bazel_skylib//rules:diff_test.bzl", "diff_test")

write_source_file(
    name = "update_expected",
    diff_test = False,
    in_file = "@starlark_uv_lock_pre_0_2_35//:raw_lock.json",
    out_file = "expected.json",
)

diff_test(
    name = "test",
    file1 = "@starlark_uv_lock_pre_0_2_35//:raw_lock.json",
    file2 = "expected.json",
    tags = ["golden"],
)
