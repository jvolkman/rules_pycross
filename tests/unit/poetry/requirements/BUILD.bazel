load("@bazel_lib//lib:write_source_files.bzl", "write_source_file")
load("@bazel_skylib//rules:diff_test.bzl", "diff_test")

write_source_file(
    name = "update_expected",
    diff_test = False,
    in_file = "@starlark_poetry_requirements//:raw_lock.json",
    out_file = "expected.json",
)

diff_test(
    name = "test",
    file1 = "@starlark_poetry_requirements//:raw_lock.json",
    file2 = "expected.json",
    tags = ["golden"],
)
